# --- Database (Railway Postgres) ---
# Local dev / migrations: use DATABASE_PUBLIC_URL from the Railway Postgres service.
# On Railway itself: reference ${{Postgres.DATABASE_URL}} (private network).
DATABASE_URL="postgresql://user:password@host:5432/railway"
# Max Postgres connections per app instance (default 10). Keep
# (instances x this) under the database's max_connections so a spike can't
# exhaust it. Requests wait up to 10s for a free connection instead of erroring.
DATABASE_POOL_MAX="10"

# --- Auth.js ---
AUTH_SECRET="generate with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"
# Public base URL for Stripe redirects + links (defaults to NEXTAUTH_URL).
APP_URL="http://localhost:3000"

# --- Cloudflare R2 (photo storage) ---
# Absent → photos fall back to local disk (dev only).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="halolabs-photos"

# --- Claude API (analysis engine) ---
# Absent → hosted analysis is disabled (jobs fail with a clear message); the
# local `claude` CLI path still works on-machine.
ANTHROPIC_API_KEY=""
# Optional model override for the hosted analysis (default: claude-sonnet-5).
ANALYSIS_MODEL="claude-sonnet-5"
# Longest-edge px cap for photos sent to the vision API (default 1568). Larger
# photos are downsampled to bound per-scan vision-token cost. Raise for more
# detail, lower to save more.
ANALYSIS_IMAGE_MAX_EDGE="1568"
# Per-user cap on hosted analyses started per hour (default 12). Bounds API burn
# from abuse/zero-intent traffic; failed jobs don't count.
ANALYSIS_HOURLY_LIMIT="12"
# How many of a person's photos the FREE teaser sends to the model (default 2 —
# the frontal shots). The paid full analysis always uses all photos. Fewer =
# cheaper free scans.
ANALYSIS_TEASER_IMAGES="2"
# Max concurrent hosted analyses in-process (default 4). Caps a viral spike so
# it queues instead of OOMing the container / blowing the Anthropic rate limit.
ANALYSIS_CONCURRENCY="4"

# --- Analytics (privacy-first, optional) ---
# Set to your site domain to enable Plausible (cookieless, no consent banner).
# Absent → no analytics loads AND server-side conversion events are a no-op, so
# attribution records nothing. MUST be set in prod. Funnel events fired: signup,
# scan_started, checkout_started, share_created, membership_active.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# Override for a self-hosted Plausible instance (defaults to plausible.io).
NEXT_PUBLIC_PLAUSIBLE_SRC=""
# API host for SERVER-SIDE Plausible events (the reliable membership_active fired
# from the Stripe webhook). Defaults to https://plausible.io; set to your
# self-hosted host if NEXT_PUBLIC_PLAUSIBLE_SRC points at one.
PLAUSIBLE_API_HOST="https://plausible.io"

# --- Marketing attribution ---
# How long the first-touch attribution cookie (hl_attr) persists, in days
# (default 90). First-party, functional, server-readable — carries utm_* /
# referrer from first landing view through to the purchase webhook.
NEXT_PUBLIC_ATTR_COOKIE_DAYS="90"

# --- Analysis worker (durable queue) ---
# The worker service (npm run worker) drains AnalysisJob rows. These tune it.
# Jobs processed concurrently per worker instance (default 4). Effective global
# concurrency = this x worker instances. (Replaces the old in-process
# ANALYSIS_CONCURRENCY, which no longer gates anything.)
WORKER_CONCURRENCY="4"
# Poll interval in ms when the queue is empty (default 1500).
WORKER_POLL_MS="1500"

# --- Stripe (billing) ---
# Absent → the paywall button returns "billing not configured".
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""   # the $9.99/mo recurring price id (price_...)
