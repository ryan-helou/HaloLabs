generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth (Auth.js / @auth/prisma-adapter standard models) ----------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Credentials sign-in: bcrypt hash. Null for OAuth-only accounts (Google, later).
  passwordHash String?
  // Hard 18+ gate, now enforced at signup — not only inside the wizard.
  ageConfirmed18Plus Boolean @default(false)

  stripeCustomerId String? @unique
  credits          Int     @default(0)
  // Entitlement flag the paywall reads. "active" lifts the blur; Stripe's
  // webhook flips this in Phase 3. Anything else (the default) keeps it locked.
  subscriptionStatus String @default("inactive")

  // First-touch marketing attribution captured at the first landing view
  // (utm_source/medium/campaign/content/term, referrer, landing_path, ts).
  // Stamped once on the guest User at scan time and carried through to the
  // purchase webhook so a sale can be credited to the content that drove it.
  attribution Json?

  accounts Account[]
  sessions Session[]
  people   Person[]
  jobs     AnalysisJob[]
  progress Progress[]
  conversions Conversion[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- HaloLabs domain ----------

model Person {
  id          String   @id @default(cuid())
  userId      String
  displayName String
  // Quiz answers / preferences ("builtFor" in the v2 results format)
  builtFor    Json?
  // Full onboarding answers (OnboardingProfile) the analysis reads — the cloud
  // equivalent of profile.json.
  profile     Json?
  createdAt   DateTime @default(now())

  // Opaque, unguessable public share id (base64url). Null = not shared. Distinct
  // from `id` so the private /person/<id> page is never implicated; maps to a
  // PII-stripped projection (lib/share.ts), never the full record.
  shareToken String? @unique
  // What the share emphasizes: "plan" (counts/composition) | "progress" (delta).
  shareKind  String?

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos  Photo[]
  jobs    AnalysisJob[]
  results AnalysisResult[]

  @@index([userId])
}

// Suggestion check-offs, per user + person + suggestion. personId is a plain
// string (not an FK) so progress works for both DB-backed and local people.
model Progress {
  userId       String
  personId     String
  suggestionId String
  done         Boolean   @default(false)
  doneAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, personId, suggestionId])
  @@index([userId, personId])
}

model Photo {
  id           String   @id @default(cuid())
  personId     String
  // Storage key (`people/<personId>/<file>`). When R2 is configured the bytes
  // live in R2 under this key; otherwise they live in PhotoBlob under the same
  // key (shared Postgres, reachable by both web and the worker service).
  r2Key        String   @unique
  originalName String?
  contentType  String?
  sizeBytes    Int?
  uploadedAt   DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
}

// Photo bytes stored in Postgres — the shared-storage fallback used when R2
// isn't configured, so the separate worker service can read photos over the
// same DB connection instead of a volume it can't reach. Keyed by the same
// storage key as Photo.r2Key. Swap to R2/MinIO later by setting R2_* — no app
// changes needed (lib/storage picks the backend).
model PhotoBlob {
  key         String   @id
  data        Bytes
  contentType String
  createdAt   DateTime @default(now())
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

// Which analysis body the worker should run for this job. TEASER = the cheap
// free scan (frontal shots only); FULL = the paid deep plan (all photos).
enum JobType {
  TEASER
  FULL
}

model AnalysisJob {
  id       String    @id @default(cuid())
  userId   String
  personId String
  status   JobStatus @default(QUEUED)
  jobType  JobType   @default(TEASER)
  error    String?

  // Retry budget: the worker bumps this on each claim; >= 3 → give up (FAILED).
  attempts Int @default(0)
  // Crash recovery lease. A RUNNING job whose lease has expired is assumed
  // orphaned (worker died / redeploy) and is requeued by the recovery sweep.
  leaseUntil DateTime?

  // Unit economics: track what each analysis actually costs
  inputTokens  Int?
  outputTokens Int?
  costCents    Int?

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  person Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  result AnalysisResult?

  @@index([status, createdAt])
  @@index([personId])
}

// A completed purchase, recorded server-side from the Stripe webhook so revenue
// can be attributed to the campaign that produced it — independent of whether
// the buyer's browser ever returned to fire a client event.
model Conversion {
  id              String   @id @default(cuid())
  userId          String?
  amountCents     Int      @default(0)
  currency        String?
  attribution     Json?
  // Stripe checkout session id — unique so a redelivered webhook can't
  // double-count the same purchase.
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model AnalysisResult {
  id       String @id @default(cuid())
  jobId    String @unique
  personId String
  // Schema version of the payload (current format: 2, matching results.json)
  version  Int
  // Full observations + plan payload, same shape the viewer already renders
  data     Json

  createdAt DateTime @default(now())

  job    AnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  person Person      @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
}
